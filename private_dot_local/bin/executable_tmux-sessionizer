#!/usr/bin/env bash

set -euo pipefail

CONFIG_FILE='tmux-sessionizer.conf'
CONFIG_DIR="${XDG_CONFIG_HOME:-${HOME}/.config}/tmux-sessionizer"
CONFIG_PATH="${CONFIG_DIR}/${CONFIG_FILE}"

# load user config
if [[ -f "${CONFIG_PATH}" ]]; then
    # shellcheck source=/dev/null
    . "${CONFIG_PATH}"
fi

# load local config
if [[ -f "./${CONFIG_FILE}" ]]; then
    # shellcheck source=/dev/null
    . "./${CONFIG_FILE}"
fi

# Search path can contain an optional ':number' suffix to control search depth.
# If set, this will override TS_MAX_DEPTH
# example:
#   TS_SEARCH_PATHS=(~/code:3 ~/git/workspace:2)
if [[ -z "${TS_SEARCH_PATHS:-}" ]]; then
    TS_SEARCH_PATHS=(~/code)
fi

if [[ -v TS_EXTRA_SEARCH_PATHS && ${#TS_EXTRA_SEARCH_PATHS[@]} -gt 0 ]]; then
    TS_SEARCH_PATHS+=("${TS_EXTRA_SEARCH_PATHS[@]}")
fi

if [[ -z "${TS_MAX_DEPTH:-}" ]]; then
    TS_MAX_DEPTH=1
fi

if [[ -f ~/.bash_aliases ]]; then
    shopt -s expand_aliases
    # shellcheck source=/dev/null
    . ~/.bash_aliases
fi

# Find directories
# Globals:
#   TMUX
#   TS_MAX_DEPTH
#   TS_SEARCH_PATHS
find_dirs() {
    # list TMUX sessions
    if [[ -n "${TMUX:-}" ]]; then
        current_session=$(tmux display-message -p '#S')
        tmux list-sessions -F '[TMUX] #{session_name}' 2>/dev/null \
            | grep -vFx "[TMUX] ${current_session}"
    else
        tmux list-sessions -F '[TMUX] #{session_name}' 2>/dev/null
    fi

    # note: TS_SEARCH_PATHS is an array of paths to search for directories
    # if the path ends with :number, it will search for directories with a max
    # depth of number ;)
    # if there is no number, it will search for directories with a max depth
    # defined by TS_MAX_DEPTH
    for entry in "${TS_SEARCH_PATHS[@]}"; do
        # Check if entry has :number as suffix then adapt the maxdepth parameter
        if [[ "${entry}" =~ ^([^:]+):([0-9]+)$ ]]; then
            path="${BASH_REMATCH[1]}"
            depth="${BASH_REMATCH[2]}"
        else
            path="${entry}"
            depth="${TS_MAX_DEPTH}"
        fi

        [[ -d "${path}" ]] \
            && find "${path}" \
                -mindepth 1 \
                -maxdepth "${depth}" \
                \( -path '*/.*' -o -path '*/__*' -o -path '*/.git*' \) -prune -o \
                -type d \
                -print
    done
}

# Prepares session environment
# Globals:
#   HOME
# Arguments:
#   session_name
#   session_path
hydrate() {
    local session_name="${1}"
    local session_path="${2}"

    local local_env="${session_path}/.tmux-sessionizer"
    local global_env="${HOME}/.tmux-sessionizer"

    if [[ -f "${local_env}" ]]; then
        log_info "sourcing (local)${local_env}"
        tmux send-keys -t "${session_name}" ". ${local_env}" c-M
    elif [[ -f "${global_env}" ]]; then
        log_info "sourcing (global)${local_env}"
        tmux send-keys -t "${session_name}" ". ${global_env}" c-M
    fi
}

log() {
    local level="${1}"
    local message="${2}"
    printf '%s - %s - %s\n' "${level}" "$(date +%Y%m%d-%H%M%S)" "${message}"
}

log_info() {
    log 'INFO' "${1}"
}

# Parses a fzf selection into selected_name / selected_path.
# Arguments:
#   selection
# Sets:
#   selected_name
#   selected_paths
parse_selection() {
    local selection="${1}"
    selected_path=""
    if [[ "${selection}" =~ ^\[TMUX\]\ (.+)$ ]]; then
        selected_name="${BASH_REMATCH[1]}"
    else
        selected_path="${selection}"
        local parent child
        parent=$(basename "$(dirname "${selection}")")
        child=$(basename "${selection}")
        selected_name=$(printf '%s/%s' "${parent}" "${child}" | tr . _)
    fi
}

# Creates a tmux session, optionally detached, with optional working dir
# Arguments:
#   session_name
#   session_path
#   detached
tmux_create_session() {
    local session_name="${1}"
    local session_path="${2}"
    local detached="${3}"

    local flag='-s'
    [[ "${detached}" == 'detached' ]] && flag='-ds'

    if [[ -n "${session_path}" ]]; then
        tmux new-session "${flag}" "${session_name}" -c "${session_path}"
        hydrate "${session_name}" "${session_path}"
    else
        tmux new-session "${flag}" "${session_name}"
    fi
}

# Checks if tmux has a session with the provided name
# Arguments:
#   session_name
tmux_has_session() {
    local session_name="${1}"
    tmux list-sessions | grep -q "^${session_name}:"
}

# Checks if tmux is running
# Globals:
#   TMUX
tmux_is_running() {
    local tmux_running
    tmux_running=$(pgrep tmux)
    if [[ -z ${TMUX:-} && -z ${tmux_running} ]]; then
        return 1
    fi
    return 0
}

# Switches tmux session
# Globals:
#   TMUX
# Arguments:
#   session_name
tmux_switch_to() {
    local session_name="${1}"
    if [[ -z "${TMUX:-}" ]]; then
        log_info "attaching to session '${session_name}'"
        tmux attach-session -t "${session_name}"
    else
        log_info "switching to session '${session_name}'"
        tmux switch-client -t "${session_name}"
    fi
}


main() {
    local selected selected_name selected_path
    selected=$(find_dirs | fzf --no-mouse)
    [[ -z "${selected:-}" ]] && exit 0

    parse_selection "${selected}"

    if ! tmux_is_running; then
        tmux_create_session "${selected_name}" "${selected_path}" ''
        exit 0
    fi

    if ! tmux_has_session "${selected_name}"; then
        tmux_create_session "${selected_name}" "${selected_path}" 'detached'
    fi

    tmux_switch_to "${selected_name}"
}

main "${@}"
