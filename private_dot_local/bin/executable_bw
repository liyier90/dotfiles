#!/usr/bin/env bash

set -euo pipefail

is_wsl2_interop() {
  [ -x /init ] &&
    [ -d /run/WSL ] &&
    [ "$(ls -A /run/WSL 2>/dev/null)" ] &&
    [ -f /proc/sys/fs/binfmt_misc/WSLInterop ]
}

bind_list=(
  'ro:/bin:/bin'
  'ro:/etc:/etc'
  'ro:/sbin:/sbin'
  'ro:/usr:/usr'
  'ro?:/lib:/lib'
  'ro?:/lib64:/lib64'
  "ro?:${HOME}/.cargo:${HOME}/.cargo"
  "ro?:${HOME}/.config:${HOME}/.config"
  "ro?:${HOME}/.local/bin:${HOME}/.local/bin"
  "ro?:${HOME}/.local/share:${HOME}/.local/share"
  "ro?:${HOME}/.nvm:${HOME}/.nvm"
  "ro?:${HOME}/.pyenv:${HOME}/.pyenv"
  "ro?:${HOME}/.rustup:${HOME}/.rustup"
  "ro?:${HOME}/.ssh:${HOME}/.ssh"
  "rw:${HOME}/.cache:${HOME}/.cache"
  "rw:${HOME}/.local/packages:${HOME}/.local/packages"
  "rw:${HOME}/.npm:${HOME}/.npm"
  "rw:${HOME}/.pi:${HOME}/.pi"
  'rw:/var/run/docker.sock:/var/run/docker.sock'
)

sandbox_path="${HOME}/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
if node_bin=$(command -v node 2>/dev/null); then
  sandbox_path="$(dirname "${node_bin}"):${sandbox_path}"
fi

env_list=(
  "PATH=${sandbox_path}"
  "HOME=${HOME}"
  "USER=${USER}"
  "TERM=${TERM:-'screen-256color'}"
)

if is_wsl2_interop; then
  bind_list+=(
    'ro:/init:/init'
    'ro:/run/WSL:/run/WSL'
    'ro?:/mnt/c:/mnt/c'
    'ro?:/mnt/wsl:/mnt/wsl'
  )
  env_list+=(
    "WSL_INTEROP=${WSL_INTEROP}"
    "WSL_DISTRO_NAME=${WSL_DISTRO_NAME}"
    "WSLENV=${WSLENV}"
  )
fi

user_config="${XDG_CONFIG_HOME:-${HOME}/.config}/bw/config"
if [ -f "${user_config}" ]; then
  # shellcheck source=/dev/null
  . "${user_config}"
fi

bind_args=()
for entry in "${bind_list[@]}"; do
  IFS=: read -r type src dest <<< "${entry}"
  case "${type}" in
    ro)
      bind_args+=(--ro-bind "${src}" "${dest}")
      ;;
    'ro?')
      bind_args+=(--ro-bind-try "${src}" "${dest}")
      ;;
    rw)
      bind_args+=(--bind "${src}" "${dest}")
      ;;
  esac
done

env_args=()
for entry in "${env_list[@]}"; do
  IFS='=' read -r key val <<< "${entry}"
  env_args+=(--setenv "${key}" "${val}")
done

workspace=$(pwd)

exec bwrap \
  --unshare-cgroup \
  --unshare-ipc \
  --unshare-pid \
  --unshare-user \
  --unshare-uts \
  --die-with-parent \
  --clearenv \
  --dev /dev \
  --proc /proc \
  --tmpfs /tmp \
  "${bind_args[@]}" \
  --bind "${workspace}" "${workspace}" \
  --chdir "${workspace}" \
  "${env_args[@]}" \
  -- \
  "${@:-/bin/bash}"
