{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "opencode": {
    },
    "opencode-go": {
      "options": {
        "apiKey": "{file:~/opencode-go}"
      },
      "whitelist": [
        "minimax-m2.5",
        "minimax-m2.7"
      ]
    }
  },
  "model": "opencode-go/minimax-m2.7",
  "small_model": "opencode/big-pickle",
  "default_agent": "plan",
  "share": "disabled",
  "autoupdate": false,
  "permission": {
    "*": "ask",
    "bash": {
      "*": "ask",
      "dir *": "allow",
      "echo *": "allow",
      "findstr *": "allow",
      "Get-ChildItem *": "allow",
      "gitingest *": "allow",
      "grep *": "allow",
      "ls *": "allow",
      "mkdir *": "allow",
      "type *": "allow",
      "node */get-shit-done/* *": "allow",
      "wc *": "allow",
      "rm *": "deny"
    },
    "external_directory": {
      "~/AppData/Local/Temp/**": "allow"
    },
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "skill": {
      "*": "allow"
    },
    "task": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "webfetch": "allow"
  },
  "mcp": {},
  "plugin": [],
  "enabled_providers": [
    "opencode",
    "opencode-go"
  ]
}

