{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "github-copilot": {
      "whitelist": [
        "gpt-4.1",
        "gpt-5-mini"
      ]
    }
  },
  "model": "github-copilot/gpt-5-mini",
  "small_model": "github-copilot/gpt-4.1",
  "theme": "tokyonight",
  "share": "disabled",
  "keybinds": {
    "leader": "\\",
    "app_exit": "ctrl+w",
    "messages_first": "ctrl+g",
    "messages_last": "ctrl+alt+g"
  },
  "autoupdate": false,
  "permission": {
    "*": "ask",
    "bash": {
      "*": "ask",
      "ls*": "allow",
      "rm*": "deny"
    },
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "webfetch": "allow"
  },
  "mcp": {},
  "enabled_providers": [
    "github-copilot"
  ]
}
